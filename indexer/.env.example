# Soroban contract address to index
CONTRACT_ID=CD3TE3IAHM737P236XZL2OYU275ZKD6MN7YH7PYYAXYIGEH55OPEWYJC

# Stellar network passphrase
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC endpoint
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://mainnet.stellar.validationcloud.io/v1/<API_KEY>
RPC_URL=https://soroban-testnet.stellar.org

# Path for the SQLite database file
DB_PATH=indexer.db

# How often to poll for new events (milliseconds)
POLL_INTERVAL_MS=5000

# HTTP port for the REST API
PORT=3001

# Ledger to start indexing from on first run.
# 0 = auto-detect (starts ~1 000 ledgers before the current tip, ~83 minutes of history).
# Set to a specific ledger sequence to replay history from that point.
START_LEDGER=0

# Rate limit window for the public API, in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per IP per window (default: 100)
RATE_LIMIT_MAX=100

# Comma-separated IPs exempt from rate limiting, e.g. internal services and monitoring
RATE_LIMIT_WHITELIST=